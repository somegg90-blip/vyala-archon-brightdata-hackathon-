# ╔══════════════════════════════════════════════════════════════════════════╗
# ║              VYALA ARCHON — Environment Variables                       ║
# ║  Copy this file to .env and fill in your credentials.                  ║
# ║  NEVER commit .env — it is in .gitignore.                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── BRIGHT DATA (required for live web scanning) ──────────────────────────────

# Master API Key
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# SERP API Zone — used to search Google for GitHub repos
BRD_SERP_USER=brd-customer-XXXXXXXX-zone-serp_api1
BRD_SERP_PASS=your_serp_password_here
BRD_SERP_ZONE=serp_api1
BRD_SERP_TOKEN=your_bright_data_api_key_here

# Web Unlocker Zone — used to download raw source files
BRD_UNLOCKER_USER=brd-customer-XXXXXXXX-zone-web_unlocker1
BRD_UNLOCKER_PASS=your_unlocker_password_here

# ── AI ENRICHMENT (OpenRouter multi-account pool) ─────────────────────────────

LLM_BASE_URL=https://openrouter.ai/api/v1

# Comma-separated list of OpenRouter API keys (one per account for resilience)
LLM_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3

# Comma-separated list of models (free tier recommended for hackathon)
LLM_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-coder:free,deepseek/deepseek-v4-flash:free

# ── SCAN BEHAVIOUR ────────────────────────────────────────────────────────────

# Set to "true" to use mock data (zero Bright Data credits, for local dev/testing)
# Set to "false" for live web scanning
MOCK_WEB=false
